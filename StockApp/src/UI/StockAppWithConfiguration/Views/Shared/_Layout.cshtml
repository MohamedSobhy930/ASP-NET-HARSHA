<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StockApp</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/StockAppWithConfiguration.styles.css" asp-append-version="true" />

    <style>
        /* --- Header Styles --- */
        .app-header {
            background-color: #ffffff;
            border-bottom: 1px solid #e5e9f2;
            padding: 0.75rem 1.5rem;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        /* Title / Brand */
        .app-title {
            font-size: 1.35rem;
            font-weight: 700;
            color: #1e293b;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 10px;
            margin-right: 2rem;
        }

            .app-title i {
                color: #0d6efd; /* Bootstrap Primary Color */
            }

        /* Navigation Links */
        .header-nav-links {
            display: flex;
            align-items: center;
            list-style: none;
            margin: 0;
            padding: 0;
            gap: 20px;
        }

            .header-nav-links a {
                text-decoration: none;
                color: #64748b; /* Slate gray */
                font-weight: 600;
                font-size: 0.95rem;
                padding: 0.5rem 0;
                border-bottom: 2px solid transparent;
                transition: all 0.2s;
            }

                .header-nav-links a:hover {
                    color: #0d6efd;
                }

                /* Active State logic */
                .header-nav-links a.active {
                    color: #0d6efd;
                    border-bottom-color: #0d6efd;
                }

        /* Search Bar */
        .search-form {
            position: relative;
        }

        .search-input {
            padding: 0.5rem 1rem 0.5rem 2.5rem; /* Space for icon */
            border: 1px solid #e2e8f0;
            border-radius: 50px;
            font-size: 0.9rem;
            width: 240px;
            background-color: #f8fafc;
            transition: all 0.2s;
        }

            .search-input:focus {
                outline: none;
                border-color: #0d6efd;
                background-color: #fff;
                box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.1);
            }

        .search-icon-btn {
            position: absolute;
            left: 10px;
            top: 50%;
            transform: translateY(-50%);
            border: none;
            background: none;
            color: #94a3b8;
        }

        /* Right Side Actions */
        .settings-icon {
            font-size: 1.25rem;
            color: #64748b;
            cursor: pointer;
            transition: transform 0.2s;
        }

            .settings-icon:hover {
                color: #1e293b;
                transform: rotate(90deg);
            }

        .btn-login {
            background-color: #0d6efd;
            color: white;
            border: none;
            padding: 0.5rem 1.25rem;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.9rem;
            transition: background 0.2s;
        }

            .btn-login:hover {
                background-color: #0b5ed7;
            }
    </style>
</head>
<body class="bg-light">

    @{
        // Simple logic to check active page
        string currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        string currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    }

    <header>
        <nav class="app-header shadow-sm d-flex justify-content-between align-items-center">

            <div class="d-flex align-items-center">
                <a class="app-title" asp-controller="Stocks" asp-action="Explore">
                    <i class="fa-solid fa-chart-line"></i>
                    Stocks
                </a>
                <ul class="header-nav-links d-none d-md-flex">
                    <li>
                        <a asp-controller="Stocks" asp-action="Explore"
                           class="@(currentController == "Stocks" && currentAction == "Explore" ? "active" : "")">
                            Explore
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Trade" asp-action="Index"
                           class="@(currentController == "Trade" && (currentAction == "Index" || currentAction == "BuyOrder" || currentAction == "SellOrder") ? "active" : "")">
                            Trade
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Trade" asp-action="Orders"
                           class="@(currentController == "Trade" && currentAction == "Orders" ? "active" : "")">
                            Orders
                        </a>
                    </li>
                </ul>
            </div>

            <div class="d-flex align-items-center gap-3">

                <form asp-controller="Trade" asp-action="Index" method="get" class="search-form d-none d-sm-block">
                    <button type="submit" class="search-icon-btn">
                        <i class="fa-solid fa-search"></i>
                    </button>
                    <input type="search" name="stockSymbol" class="search-input" placeholder="Search Stocks..." />
                </form>

                <i class="fa-solid fa-gear settings-icon" title="Settings"></i>
                <button class="btn-login shadow-sm">Login</button>
            </div>
        </nav>
    </header>

    <div class="container-fluid">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-white mt-5 py-4">
        <div class="container text-center">
            &copy; 2025 - StockApp - <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>