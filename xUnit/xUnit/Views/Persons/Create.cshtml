@using ServiceContacts.DTOs.PersonDto
@using ServiceContacts.Enums
@model PersonAddRequest

@{
    ViewBag.Title = "Create Person";
}

<div class="container my-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-1">Create Person</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-controller="Persons" asp-action="Index" class="text-decoration-none">Persons</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Create</li>
                </ol>
            </nav>
        </div>
        <a asp-controller="Persons" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-5">
            <form asp-controller="Persons" asp-action="Create" method="post">

                <div class="row g-4 mb-3">
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label fw-semibold">Person Name</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted"><i class="bi bi-person"></i></span>
                            <input asp-for="Name" class="form-control" placeholder="e.g. John Doe" />
                        </div>
                        <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-semibold">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <div class="row g-4 mb-3">
                    <div class="col-md-6">
                        <label asp-for="DateOfBirth" class="form-label fw-semibold">Date of Birth</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted"><i class="bi bi-calendar-event"></i></span>
                            <input asp-for="DateOfBirth" type="date" class="form-control" />
                        </div>
                        <span asp-validation-for="DateOfBirth" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold d-block">Gender</label>
                        <div class="d-flex gap-4 mt-2">
                            <div class="form-check">
                                <input asp-for="Gender" type="radio" value="Male" class="form-check-input" id="genderMale" />
                                <label class="form-check-label" for="genderMale">Male</label>
                            </div>
                            <div class="form-check">
                                <input asp-for="Gender" type="radio" value="Female" class="form-check-input" id="genderFemale" />
                                <label class="form-check-label" for="genderFemale">Female</label>
                            </div>
                            <div class="form-check">
                                <input asp-for="Gender" type="radio" value="Other" class="form-check-input" id="genderOther" />
                                <label class="form-check-label" for="genderOther">Other</label>
                            </div>
                        </div>
                        <span asp-validation-for="Gender" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <div class="row g-4 mb-3">
                    <div class="col-md-6">
                        <label asp-for="CountryId" class="form-label fw-semibold">Country</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted"><i class="bi bi-globe"></i></span>
                            <select asp-for="CountryId" asp-items="@ViewBag.Countries" class="form-select">
                                <option value="">-- Select Country --</option>
                            </select>
                        </div>
                        <span asp-validation-for="CountryId" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Address" class="form-label fw-semibold">Address</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted"><i class="bi bi-geo-alt"></i></span>
                            <textarea asp-for="Address" class="form-control" rows="1" placeholder="Street, City, Zip"></textarea>
                        </div>
                        <span asp-validation-for="Address" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <div class="form-check form-switch">
                        <input asp-for="ReceiveNewsletter" class="form-check-input" type="checkbox" id="newsletterCheck">
                        <label class="form-check-label" for="newsletterCheck">
                            Subscribe to Newsletter
                        </label>
                    </div>
                </div>

                <div class="d-flex justify-content-end pt-3 border-top">
                    <button type="submit" class="btn btn-primary px-5 btn-lg shadow-sm">
                        <i class="bi bi-check-circle me-1"></i> Create
                    </button>
                </div>

                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="alert alert-danger mt-3 mb-0" role="alert">
                        <ul class="mb-0 ps-3">
                            <div asp-validation-summary="All"></div>
                        </ul>
                    </div>
                }
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js" integrity="sha512-rstIgDs0xPgmG6RX1Aba4KV5cWJbAMcvRCVmglpam9SoHZiUCyQVDdH2LPlxoHtrv17XWblE/V/PP+Tr04hbtA==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js" integrity="sha512-xq+Vm8jC94ynOikewaQXMEkJIOBp7i7u7CpUzYXJG8ZNvoqBPMmnrxQVhPOqJ4JuejUL4PfI6r6QZiGTl476Vg==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
}