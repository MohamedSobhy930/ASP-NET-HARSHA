<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CRUD Demo</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/xUnit.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">

    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm mb-4 py-3">
            <div class="container">
                <a class="navbar-brand fw-bold fs-4 text-primary" asp-controller="Persons" asp-action="Index">
                    <i class="bi bi-database me-1"></i> CRUD Demo
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">

                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-2">
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold" asp-controller="Persons" asp-action="Index">Persons</a>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-danger fw-bold" asp-area="Admin" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-shield-lock me-1"></i> Admin Panel
                                </a>
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center gap-3 mt-3 mt-lg-0">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <span class="text-muted fw-medium">
                                <i class="bi bi-person-circle text-primary me-1"></i> Hello, @User.Identity.Name!
                            </span>
                            <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger btn-sm shadow-sm">
                                <i class="bi bi-box-arrow-right me-1"></i> Logout
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Register" class="btn btn-outline-primary shadow-sm">
                                Register
                            </a>
                            <a asp-controller="Account" asp-action="Login" class="btn btn-primary shadow-sm">
                                <i class="bi bi-box-arrow-in-right me-1"></i> Login
                            </a>
                        }
                    </div>

                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="container page-content flex-grow-1">
        @RenderBody()
    </main>

    <footer class="border-top footer text-muted bg-white py-4 mt-5">
        <div class="container text-center">
            &copy; @DateTime.Now.Year - CRUD Demo Application
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>