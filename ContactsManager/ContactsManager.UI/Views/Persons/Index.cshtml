@using ServiceContacts.DTOs.PersonDto
@using ServiceContacts.Enums
@model IEnumerable<PersonResponse>

@{
    ViewBag.Title = "Persons List";

    async Task RenderSortableHeader(string fieldName, string displayName)
    {
        var isCurrentSort = ViewBag.CurrentSortBy == fieldName;
        var nextSortDirection = isCurrentSort && ViewBag.CurrentSortDirection == SortDirectionOptions.ASC
            ? SortDirectionOptions.DESC
            : SortDirectionOptions.ASC;

        var nextIcon = nextSortDirection == SortDirectionOptions.ASC ? "bi-sort-alpha-down" : "bi-sort-alpha-down-alt";

        <a asp-controller="Persons"
           asp-action="Index"
           asp-route-searchBy="@ViewBag.CurrentSearchBy"
           asp-route-searchPhrase="@ViewBag.CurrentSearchPhrase"
           asp-route-sortBy="@fieldName"
           asp-route-sortDirection="@nextSortDirection"
           class="text-decoration-none text-dark fw-bold d-block">
            @displayName
            @if (isCurrentSort)
            {
                <i class="bi @(ViewBag.CurrentSortDirection == SortDirectionOptions.ASC ? "bi-caret-up-fill" : "bi-caret-down-fill") ms-1 text-primary"></i>
            }
            else
            {
                <i class="bi bi-arrow-down-up ms-1 text-muted opacity-25"></i>
            }
        </a>
    }
}

<div class="container my-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-1">Persons</h2>
            <p class="text-muted mb-0">Manage your contacts and their details.</p>
        </div>

        <div class="d-flex gap-2">
            <a asp-controller="Persons" asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-lg me-1"></i> Create Person
            </a>

            <div class="dropdown">
                <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-download me-1"></i> Export
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow">
                    <li>
                        <a class="dropdown-item" asp-controller="Persons" asp-action="PersonsPDF">
                            <i class="bi bi-file-earmark-pdf text-danger me-2"></i> Download as PDF
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item" asp-controller="Persons" asp-action="PersonsExcel">
                            <i class="bi bi-file-earmark-excel text-success me-2"></i> Download as Excel
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item" asp-controller="Persons" asp-action="PersonsCSV">
                            <i class="bi bi-filetype-csv text-primary me-2"></i> Download as CSV
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4 bg-light">
        <div class="card-body py-3">
            <form asp-controller="Persons" asp-action="Index" method="get" class="row g-2 align-items-center">
                <div class="col-md-10">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="bi bi-search text-muted"></i>
                        </span>

                        <select name="searchBy" class="form-select" style="max-width: 200px; background-color: #f8f9fa;">
                            @foreach (var field in ViewBag.SearchFields)
                            {
                                if (field.Key == ViewBag.CurrentSearchBy)
                                {
                                    <option value="@field.Key" selected="selected">@field.Value</option>
                                }
                                else
                                {
                                    <option value="@field.Key">@field.Value</option>
                                }
                            }
                        </select>

                        <input type="search" name="searchPhrase" value="@ViewBag.CurrentSearchPhrase"
                               class="form-control border-start-0 ps-3" placeholder="Search for names, emails, countries..." />

                        <button type="submit" class="btn btn-primary px-4">Search</button>
                    </div>
                </div>

                <div class="col-md-2 text-end">
                    <a asp-controller="Persons" asp-action="Index" class="btn btn-link text-decoration-none text-muted">
                        Clear Filters
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="py-3 ps-4">@{
                        RenderSortableHeader("Name", "Person");
                                                }
</th>
                        <th class="py-3">Email</th>
                        <th class="py-3">@{
                                                RenderSortableHeader("DateOfBirth", "Date of Birth");
                                                }
</th>
                        <th class="py-3">@{
                                                RenderSortableHeader("Age", "Age");
                                                }
</th>
                        <th class="py-3">@{
                                                RenderSortableHeader("Gender", "Gender");
                                                }
</th>
                        <th class="py-3">@{
                                                RenderSortableHeader("Country", "Country");
                                                }
</th>
                        <th class="py-3">Newsletter</th>
                        <th class="py-3 text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var person in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px; font-weight: bold;">
                                            @person.Name?[0]
                                        </div>
                                        <div>
                                            <div class="fw-bold">@person.Name</div>
                                            <div class="small text-muted">ID: @person.Id.ToString().Substring(0, 8)...</div>
                                        </div>
                                    </div>
                                </td>
                                <td><a href="mailto:@person.Email" class="text-decoration-none text-secondary">@person.Email</a></td>
                                <td>@person.DateOfBirth?.ToString("dd MMM yyyy")</td>
                                <td><span class="badge bg-light text-dark border">@person.Age yrs</span></td>
                                <td>@person.Gender</td>
                                <td>@person.Country</td>
                                <td>
                                    @if (person.ReceiveNewsletter == true)
                                    {
                                        <i class="bi bi-check-circle-fill text-success fs-5" title="Subscribed"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-dash-circle text-muted fs-5 opacity-50" title="Not Subscribed"></i>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group" role="group">
                                        <a asp-controller="Persons" asp-action="Update" asp-route-id="@person.Id"
                                           class="btn btn-sm btn-outline-secondary border-0" title="Edit">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a asp-controller="Persons" asp-action="Delete" asp-route-id="@person.Id"
                                           class="btn btn-sm btn-outline-danger border-0"
                                           onclick="return confirm('Are you sure you want to delete @person.Name?');" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5">
                                <div class="text-muted">
                                    <i class="bi bi-search display-6 mb-3 d-block opacity-50"></i>
                                    <span class="h5 fw-normal">No persons found matching your criteria.</span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="text-end mt-2 text-muted small">
        Showing @Model?.Count() records
    </div>
</div>